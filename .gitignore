.env
output/

media/

.venv/
.venv-voiceclone/
__pycache__/
*.pyc

# Large/generated multimedia artifacts
*.mp4
*.mov
*.mkv
*.avi
*.webm

# Ignore generic audio exports by default
*.wav
*.mp3
*.m4a

# Keep only reference voices under voces/
!voces/
!voces/*.wav
!voces/*.mp3
!voces/*.m4a

storage/app.db

.pytest_cache/
.mypy_cache/
.ruff_cache/
